# Keep the build context small. NOTE: data/ is intentionally NOT ignored so the
# MNIST files are baked into the image (no runtime download).
.git
.gitignore
.vscode
__pycache__
**/__pycache__
*.pyc
logs
checkpoints
docs
backup_codes
client/backup_client_code.py
*.log
Dockerfile
.dockerignore
docker-compose.yml
README.md
